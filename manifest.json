{
	"id": "hide-completed-todos",
	"name": "Hide Completed Todos",
	"version": "0.1.0",
	"author": "Your Name",
	"description": "Hides the content of completed todos.",
	"minAppVersion": "0.9.7",
	"permissions": [
		"activeTab"
	],
	"background": {
		"scripts": ["background.js"]
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"]
		}
	]
}
